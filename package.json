{
  "name": "dse-ai",
  "version": "0.1.0",
  "description": "AI-friendly CLI for Dhaka Stock Exchange - scrapes data from dsebd.org",
  "type": "module",
  "main": "dist/cli.js",
  "bin": {
    "dse-ai": "dist/cli.js"
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "dev": "tsx src/cli.ts",
    "build": "tsc && chmod +x dist/cli.js",
    "start": "node dist/cli.js",
    "link": "npm run build && npm link",
    "prepublishOnly": "npm run build && npm test",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run tests/unit",
    "test:integration": "vitest run tests/integration"
  },
  "keywords": [
    "dse",
    "dhaka-stock-exchange",
    "stock-market",
    "bangladesh",
    "cli",
    "scraper",
    "typescript",
    "ai-tools"
  ],
  "author": "",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/auniik/dse-ai.git"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "cheerio": "^1.2.0",
    "cli-table3": "^0.6.5",
    "commander": "^11.1.0",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.11.16",
    "@vitest/coverage-v8": "^1.2.2",
    "tsx": "^4.7.1",
    "typescript": "^5.3.3",
    "vitest": "^1.2.2"
  }
}
